# Dynamic-linked nim test-node, for the Shadow simulator.
#
# Mirrors Dockerfile_amd64 but DROPS the static linker flags
# (`--passL:"-static -mmusl"` and `--passL:"-static-libgcc -static-libstdc++"`).
#
# Why: Shadow's syscall interposer is LD_PRELOAD-based and only hooks
# dynamically linked ELFs. A statically linked nim binary fails at startup with
# "Failed to verify plugin path '...': not a dynamically linked ELF".
#
# Build via kaniko on a lab worker (see shadow/kaniko-build-test-node-job.yaml).
# Pushes to radiken/dst-test-node-shadow:latest.

FROM debian:bookworm-slim AS builder

WORKDIR /node

RUN apt-get update && apt-get install -y \
    curl git build-essential ca-certificates \
    libssl3 iproute2 procps xz-utils \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

RUN git config --global http.sslVerify false

RUN curl https://nim-lang.org/download/nim-2.2.6-linux_x64.tar.xz -o /tmp/nim.tar.xz \
    && tar -xf /tmp/nim.tar.xz -C /tmp \
    && cp -r /tmp/nim-2.2.6/* /usr/local \
    && rm -rf /usr/local/nim* && mv /tmp/nim-2.2.6 /usr/local/nim-2.2.6 \
    && ln -sf /usr/local/nim-2.2.6/bin/nim /usr/local/bin/nim \
    && ln -sf /usr/local/nim-2.2.6/bin/nimble /usr/local/bin/nimble

COPY . .

RUN nimble refresh
RUN nimble install -dy --verbose

# Dynamic link: no `-static`, no `-mmusl`, no `-static-libgcc/-libstdc++`.
RUN nimble c \
    --os:linux --cpu:amd64 \
    -d:chronicles_colors=None --threads:on --mm:refc \
    -d:metrics -d:libp2p_network_protocols_metrics -d:release \
    main \
    && chmod +x /node/main

# Tiny final stage: the binary + its runtime deps. The image's role is to hand
# off /node/main to an init container, not to run anything itself. We still
# include glibc/libssl/libstdc++ in case someone wants to `docker run` it.
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 libgcc-s1 libstdc++6 ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

COPY --from=builder /node/main /node/main

ENTRYPOINT ["/node/main"]
