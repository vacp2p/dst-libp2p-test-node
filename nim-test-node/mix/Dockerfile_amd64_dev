# syntax=docker/dockerfile:1
# Fast-iteration dev variant of Dockerfile_amd64_shadow.
#
# Differences from the shadow image:
#   - No -d:release. Substantially faster compile, larger and slower binary.
#   - Separate nim cache scope (id=nim-dev) so dev/release builds don't
#     invalidate each other.
#
# Trade-off: larger binary, no compiler optimization. Fine for smoke + local
# iteration. NOT for Shadow runs or any latency-sensitive measurement — use
# Dockerfile_amd64_shadow for those.

FROM debian:bookworm-slim AS builder

WORKDIR /node

RUN apt-get update && apt-get install -y \
    curl git build-essential ca-certificates \
    libssl3 iproute2 procps xz-utils \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

RUN git config --global http.sslVerify false

RUN curl https://nim-lang.org/download/nim-2.2.6-linux_x64.tar.xz -o /tmp/nim.tar.xz \
    && tar -xf /tmp/nim.tar.xz -C /tmp \
    && cp -r /tmp/nim-2.2.6/* /usr/local \
    && rm -rf /usr/local/nim* && mv /tmp/nim-2.2.6 /usr/local/nim-2.2.6 \
    && ln -sf /usr/local/nim-2.2.6/bin/nim /usr/local/bin/nim \
    && ln -sf /usr/local/nim-2.2.6/bin/nimble /usr/local/bin/nimble

# Copy only the nimble file first so the dep install layer caches across code edits.
COPY test_node.nimble .

RUN nimble refresh
RUN nimble install -dy --verbose

# Now copy the rest of the source; only the compile step re-runs on code changes.
COPY . .

# Cache mount on Nim's compile cache so rebuilds only recompile changed sources.
RUN --mount=type=cache,id=nim-dev,target=/root/.cache/nim \
    nimble c \
    --os:linux --cpu:amd64 \
    -d:chronicles_colors=None --threads:on --mm:refc \
    -d:metrics -d:libp2p_network_protocols_metrics \
    main \
    && chmod +x /node/main

# Tiny final stage: the binary + its runtime deps. The image's role is to hand
# off /node/main to an init container, not to run anything itself. We still
# include glibc/libssl/libstdc++ in case someone wants to `docker run` it.
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 libgcc-s1 libstdc++6 ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

COPY --from=builder /node/main /node/main

# Default pubInfo exchange dir; bind-mount the same path across pods to share files.
ENV FILEPATH=/data
VOLUME ["/data"]

ENTRYPOINT ["/node/main"]
